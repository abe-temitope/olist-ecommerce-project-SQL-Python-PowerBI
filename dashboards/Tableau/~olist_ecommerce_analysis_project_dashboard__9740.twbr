      <column caption='Net Revenue' datatype='real' name='[Calculation_685391633113206784]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Total revenue&#13;&#10;SUM(&#13;&#10;IF [order_status] = &quot;delivered&quot;&#13;&#10;THEN [price]&#13;&#10;END&#13;&#10;)' />
      </column>
      <column caption='Gross Revenue' datatype='real' name='[Calculation_685391633133084673]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Gross revenue&#13;&#10;[price] + [freight_value]' />
      </column>
      <column caption='Total Orders' datatype='integer' name='[Calculation_685391633133785090]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// total orders&#13;&#10;COUNTD([order_id])' />
      </column>
      <column caption='Total Customers' datatype='integer' name='[Calculation_685391633134182403]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// total customers&#13;&#10;COUNTD([customer_id])' />
      </column>
      <column caption='AOV' datatype='real' name='[Calculation_685391633134358532]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// average order value&#13;&#10;[Calculation_685391633113206784] / [Calculation_685391633133785090]' />
      </column>
      <column caption='Month Year' datatype='string' name='[Calculation_685391633155629061]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='DATENAME(&apos;month&apos;, [order_delivered_customer_date]) + &quot; &quot; +&#13;&#10;STR(YEAR([order_delivered_customer_date]))' />
      </column>
      <column caption='Midian Revenue' datatype='real' name='[Calculation_685391633355763721]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MEDIAN( IF [order_status] = &quot;delivered&quot;&#13;&#10;THEN [price]&#13;&#10;END&#13;&#10;)' />
      </column>
